<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ProofReader — {{ job_id }}</title>
  <style>
    body { font-family: sans-serif; max-width: 960px; margin: 2em auto; padding: 0 1em; color: #222; }
    h1 { font-size: 1.4em; margin-bottom: 0.25em; }
    .meta { font-size: 0.9em; color: #555; margin-bottom: 1.5em; }
    .verdict { display: inline-block; padding: 0.2em 0.6em; border-radius: 3px; font-weight: bold; }
    .verdict-PASS          { background: #d4edda; color: #155724; }
    .verdict-WARN          { background: #fff3cd; color: #856404; }
    .verdict-ABSENT        { background: #fff3cd; color: #856404; }
    .verdict-FAIL          { background: #f8d7da; color: #721c24; }
    .verdict-INDETERMINATE { background: #e2e3e5; color: #383d41; }
    .verdict-ERROR         { background: #f8d7da; color: #721c24; }
    table { border-collapse: collapse; width: 100%; margin: 1em 0; font-size: 0.9em; }
    th, td { border: 1px solid #ccc; padding: 0.4em 0.6em; text-align: left; vertical-align: top; }
    th { background: #f5f5f5; }
    .note { color: #555; font-size: 0.85em; }
    img { max-width: 100%; height: auto; border: 1px solid #ddd; }
    details { margin-top: 1.5em; }
    details summary { cursor: pointer; font-size: 0.9em; color: #555; }
    details pre { font-size: 0.8em; overflow-x: auto; background: #f8f8f8;
                  border: 1px solid #ddd; padding: 0.5em; max-height: 400px; overflow-y: auto; }
  </style>
</head>
<body>
{% block content %}{% endblock %}
</body>
</html>
